{
  "version": 2,
  "functions": {
    "api/index.js": {
      "memory": 1024,  // Adjust if needed for DB connections
      "maxDuration": 60  // For long-running ops like DB connects
    }
  },
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/index.js"  // Routes everything under /api to your Express handler
    },
    {
      "source": "/(.*)",  // For your React app (client-side routing)
      "destination": "/index.html"  // Assuming a single-page app build
    }
  ],
  "headers": [
    {
      "source": "/api/:path*",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET, POST, PUT, DELETE, OPTIONS" },
        { "key": "Access-Control-Allow-Headers", "value": "Content-Type, Authorization" }
      ]
    }
  ]
}
